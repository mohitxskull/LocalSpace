{
  "name": "@localspace/ui",
  "version": "0.0.0",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "prettier": "@adonisjs/prettier-config",
  "files": [
    "build",
    "!build/bin"
  ],
  "exports": {
    "./components": "./build/src/components/index.js",
    "./configs/*": "./build/src/configs/*.js",
    "./lib/*": "./build/src/lib/*.js"
  },
  "scripts": {
    "clean": "del-cli build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "prebuild": "nr clean",
    "build": "tsc",
    "playground": "tsx bin/playground.ts",
    "check": "nr format && nr typecheck && nr lint"
  },
  "devDependencies": {
    "@adonisjs/eslint-config": "^2.1.2",
    "@adonisjs/prettier-config": "^1.4.5",
    "@adonisjs/tsconfig": "^1.4.1",
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cpy-cli": "^5.0.0",
    "del-cli": "^5.1.0",
    "eslint": "^9.34.0",
    "eslint-config-next": "15.5.2",
    "eslint-plugin-import": "^2.32.0",
    "prettier": "^3.5.3",
    "typescript": "^5"
  },
  "peerDependencies": {
    "@mantine/core": "8.*",
    "@mantine/form": "8.*",
    "@mantine/notifications": "8.*",
    "@tanstack/react-query": "5.*",
    "next": "15.*",
    "react": "19.*",
    "react-dom": "19.*",
    "@tuyau/client": "0.2.11-next.2",
    "zod": "4.*"
  },
  "dependencies": {
    "@marsidev/react-turnstile": "^1.3.0",
    "cookies-next": "^6.1.0"
  }
}
